diff --git a/gui/common/ui/view_adapters/graph_canvas.slint b/gui/common/ui/view_adapters/graph_canvas.slint
new file mode 100644
index 0000000..b144e1b
--- /dev/null
+++ b/gui/common/ui/view_adapters/graph_canvas.slint
@@ -0,0 +1,38 @@
+export struct GraphNodeInfo {
+    instance_id: int,  // unique per dropped instance, matches dsp::pedal::graph::NodeId
+    type_id: int,      // which pedal type this is, for display/spawning
+    name: string,
+    x: length,         // top-left position in canvas (unpanned/"world") space
+    y: length,
+}
+
+export struct WireInfo {
+    from_id: int,      // instance_id of the upstream (output) node
+    to_id: int,        // instance_id of the downstream (input) node
+}
+
+export global GraphCanvasAdapter {
+    in property <[GraphNodeInfo]> nodes;
+    in property <[WireInfo]> wires;
+
+    // Pan offset of the canvas, in canvas/world coordinates. Kept as
+    // in-out so the canvas component can drive it directly while panning,
+    // without needing a callback round-trip for every frame of the drag.
+    in-out property <length> pan_x;
+    in-out property <length> pan_y;
+
+    // A pedal type was dropped onto the canvas at this world position.
+    callback node_dropped(int /* type_id */, length /* x */, length /* y */);
+
+    // An existing node finished being dragged to a new world position.
+    callback node_moved(int /* instance_id */, length /* x */, length /* y */);
+
+    callback node_removed(int /* instance_id */);
+
+    // A wire was dragged from an output port to an input port and released
+    // over a valid target. Rejecting the connection (e.g. it would create a
+    // cycle) is the caller's job; the canvas doesn't know about that.
+    callback wire_completed(int /* from_id */, int /* to_id */);
+
+    callback wire_removed(int /* from_id */, int /* to_id */);
+}
