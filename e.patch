diff --git a/gui/common/ui/components/graph_canvas.slint b/gui/common/ui/components/graph_canvas.slint
new file mode 100644
index 0000000..b2ed4cd
--- /dev/null
+++ b/gui/common/ui/components/graph_canvas.slint
@@ -0,0 +1,320 @@
+import { Palette } from "std-widgets.slint";
+
+import { GraphCanvasAdapter, GraphNodeInfo, WireInfo } from "@root/view_adapters.slint";
+
+// Visual size of a node box on the canvas. Kept as globals so the port-dot
+// positions used for wire endpoints agree with what GraphNode actually draws.
+export global GraphMetrics {
+    out property <length> node-width: 140px;
+    out property <length> node-height: 64px;
+    out property <length> port-radius: 7px;
+}
+
+// A single bezier wire between two world-space points. Drawn with a gentle
+// horizontal S-curve so wires stay readable even when nodes overlap vertically.
+component Wire {
+    in property <length> from-x;
+    in property <length> from-y;
+    in property <length> to-x;
+    in property <length> to-y;
+    in property <bool> highlighted: false;
+
+    // Bounding box for the Path's own coordinate space; Path draws in
+    // logical pixels from (0,0) at top-left of this component.
+    x: Math.min(from-x, to-x) - 2px;
+    y: Math.min(from-y, to-y) - 2px;
+    width: Math.max(from-x, to-x) - Math.min(from-x, to-x) + 4px;
+    height: Math.max(from-y, to-y) - Math.min(from-y, to-y) + 4px;
+
+    Path {
+        width: 100%;
+        height: 100%;
+        viewbox-x: 0;
+        viewbox-y: 0;
+        viewbox-width: parent.width / 1px;
+        viewbox-height: parent.height / 1px;
+
+        stroke: highlighted ? Palette.foreground : Palette.border;
+        stroke-width: highlighted ? 3px : 2px;
+
+        MoveTo {
+            x: (from-x - parent.x) / 1px;
+            y: (from-y - parent.y) / 1px;
+        }
+
+        // Horizontal S-curve: control points pulled out to either side
+        // along x, so the wire always leaves/enters ports horizontally
+        // regardless of relative vertical position.
+        CubicTo {
+            control-1-x: (from-x - parent.x) / 1px + 60;
+            control-1-y: (from-y - parent.y) / 1px;
+            control-2-x: (to-x - parent.x) / 1px - 60;
+            control-2-y: (to-y - parent.y) / 1px;
+            x: (to-x - parent.x) / 1px;
+            y: (to-y - parent.y) / 1px;
+        }
+    }
+}
+
+// One draggable pedal instance box with an input port (left) and output
+// port (right). Dragging the body moves the node; dragging from the
+// output port starts a wire.
+component GraphNode {
+    in property <string> name;
+    in property <int> instance_id;
+    in-out property <length> node-x;
+    in-out property <length> node-y;
+
+    callback moved(length /* x */, length /* y */);
+    callback dragging(length /* x */, length /* y */);
+    callback removed();
+
+    // Emitted continuously while dragging out of the output port, in
+    // canvas-local coordinates, so the parent Canvas can draw a live
+    // preview wire following the pointer.
+    callback output-drag(length /* x */, length /* y */);
+    callback output-drag-ended(length /* x */, length /* y */);
+
+    width: GraphMetrics.node-width;
+    height: GraphMetrics.node-height;
+    x: node-x;
+    y: node-y;
+
+    body := Rectangle {
+        background: Palette.alternate-background;
+        border-radius: 8px;
+        border-width: 1px;
+        border-color: Palette.border;
+
+        Text {
+            text: root.name;
+            horizontal-alignment: center;
+            vertical-alignment: center;
+            width: 100%;
+            height: 100%;
+        }
+
+        body-drag := TouchArea {
+            property <length> press-node-x;
+            property <length> press-node-y;
+
+            pointer-event(event) => {
+                if (event.kind == PointerEventKind.down) {
+                    press-node-x = root.node-x;
+                    press-node-y = root.node-y;
+                }
+                if (event.kind == PointerEventKind.up) {
+                    root.moved(root.node-x, root.node-y);
+                }
+                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
+                    root.removed();
+                }
+            }
+
+            moved => {
+                if (self.pressed) {
+                    root.node-x = press-node-x + (self.mouse-x - self.pressed-x);
+                    root.node-y = press-node-y + (self.mouse-y - self.pressed-y);
+                    root.dragging(root.node-x, root.node-y);
+                }
+            }
+        }
+    }
+
+    // Output port: right-center. Dragging from here starts a new wire.
+    Rectangle {
+        x: parent.width - GraphMetrics.port-radius;
+        y: parent.height / 2 - GraphMetrics.port-radius;
+        width: GraphMetrics.port-radius * 2;
+        height: GraphMetrics.port-radius * 2;
+        border-radius: GraphMetrics.port-radius;
+        background: Palette.foreground;
+        border-width: 1px;
+        border-color: Palette.border;
+
+        output-drag-area := TouchArea {
+            moved => {
+                if (self.pressed) {
+                    root.output-drag(
+                        root.node-x + parent.x + parent.width / 2 + (self.mouse-x - self.pressed-x),
+                        root.node-y + parent.y + parent.height / 2 + (self.mouse-y - self.pressed-y),
+                    );
+                }
+            }
+
+            pointer-event(event) => {
+                if (event.kind == PointerEventKind.up) {
+                    root.output-drag-ended(
+                        root.node-x + parent.x + parent.width / 2 + (self.mouse-x - self.pressed-x),
+                        root.node-y + parent.y + parent.height / 2 + (self.mouse-y - self.pressed-y),
+                    );
+                }
+            }
+        }
+    }
+
+    // Input port: left-center. Purely visual anchor here; hit-testing for
+    // "did a dragged wire land on this port" happens in GraphCanvas since
+    // it already has every node's geometry in one place.
+    Rectangle {
+        x: -GraphMetrics.port-radius;
+        y: parent.height / 2 - GraphMetrics.port-radius;
+        width: GraphMetrics.port-radius * 2;
+        height: GraphMetrics.port-radius * 2;
+        border-radius: GraphMetrics.port-radius;
+        background: Palette.foreground.with-alpha(0.6);
+        border-width: 1px;
+        border-color: Palette.border;
+    }
+}
+
+export component GraphCanvas {
+    in-out property <[GraphNodeInfo]> nodes: GraphCanvasAdapter.nodes;
+    in-out property <[WireInfo]> wires: GraphCanvasAdapter.wires;
+    in-out property <length> pan-x <=> GraphCanvasAdapter.pan_x;
+    in-out property <length> pan-y <=> GraphCanvasAdapter.pan_y;
+
+    // Live wire-drag preview state; -1 means "not dragging a wire".
+    property <int> dragging-from: -1;
+    property <length> drag-x;
+    property <length> drag-y;
+
+    clip: true;
+
+    Rectangle {
+        width: 100%;
+        height: 100%;
+        background: Palette.background;
+    }
+
+    background-area := TouchArea {
+        property <length> press-pan-x;
+        property <length> press-pan-y;
+
+        pointer-event(event) => {
+            if (event.kind == PointerEventKind.down) {
+                press-pan-x = root.pan-x;
+                press-pan-y = root.pan-y;
+            }
+        }
+
+        moved => {
+            if (self.pressed) {
+                root.pan-x = press-pan-x + (self.mouse-x - self.pressed-x);
+                root.pan-y = press-pan-y + (self.mouse-y - self.pressed-y);
+            }
+        }
+    }
+
+    content := Rectangle {
+        x: root.pan-x;
+        y: root.pan-y;
+        width: 100%;
+        height: 100%;
+
+        if root.nodes.length == 0 && root.dragging-from < 0: Text {
+            text: "Drop a pedal here";
+            color: Palette.foreground.with-alpha(0.5);
+            x: (parent.width - self.width) / 2;
+            y: (parent.height - self.height) / 2;
+        }
+
+        // Wires, drawn under the node boxes.
+        for wire in root.wires: Wire {
+            from-x: root.port-x-for(wire.from_id, true);
+            from-y: root.port-y-for(wire.from_id);
+            to-x: root.port-x-for(wire.to_id, false);
+            to-y: root.port-y-for(wire.to_id);
+        }
+
+        // Live preview wire while dragging a new connection out of a port.
+        if root.dragging-from >= 0: Wire {
+            from-x: root.port-x-for(root.dragging-from, true);
+            from-y: root.port-y-for(root.dragging-from);
+            to-x: root.drag-x;
+            to-y: root.drag-y;
+            highlighted: true;
+        }
+
+        for node[index] in root.nodes: GraphNode {
+            name: node.name;
+            instance_id: node.instance_id;
+            node-x: node.x;
+            node-y: node.y;
+
+            // Fired on every pointer move while dragging (not just on
+            // release) so wires attached to this node track it live rather
+            // than jumping into place only once the drag ends.
+            dragging(x, y) => {
+                root.nodes[index].x = x;
+                root.nodes[index].y = y;
+            }
+
+            moved(x, y) => {
+                root.nodes[index].x = x;
+                root.nodes[index].y = y;
+                GraphCanvasAdapter.node_moved(node.instance_id, x, y);
+            }
+
+            removed => {
+                GraphCanvasAdapter.node_removed(node.instance_id);
+            }
+
+            output-drag(x, y) => {
+                root.dragging-from = node.instance_id;
+                root.drag-x = x;
+                root.drag-y = y;
+            }
+
+            output-drag-ended(x, y) => {
+                root.complete-wire-drag(node.instance_id, x, y);
+                root.dragging-from = -1;
+            }
+        }
+    }
+
+    // Looks up the world-space position (i.e. `content`-local, before the
+    // `root.pan-x/y` offset that `content` itself already carries) of a
+    // node's output (right) or input (left) port center, given its
+    // instance_id. Since Wire/the drag preview live inside `content`,
+    // which is already translated by pan-x/pan-y, these must return
+    // coordinates *relative to content*, not the outer canvas.
+    function port-x-for(instance_id: int, output: bool) -> length {
+        for node in root.nodes {
+            if (node.instance_id == instance_id) {
+                return output
+                    ? node.x + GraphMetrics.node-width
+                    : node.x;
+            }
+        }
+        return 0px;
+    }
+
+    function port-y-for(instance_id: int) -> length {
+        for node in root.nodes {
+            if (node.instance_id == instance_id) {
+                return node.y + GraphMetrics.node-height / 2;
+            }
+        }
+        return 0px;
+    }
+
+    // Hit-tests the drop point (arriving in `content`-local coordinates,
+    // same space GraphNode's output-drag reports in) against every other
+    // node's input port, and fires wire_completed for the first match
+    // within range. Cycle rejection etc. is left to whoever handles the
+    // callback on the Rust side.
+    function complete-wire-drag(from_id: int, to-x: length, to-y: length) {
+        for node in root.nodes {
+            if (node.instance_id != from_id) {
+                if (
+                    Math.abs((to-x - node.x) / 1px) < 24
+                    && Math.abs((to-y - node.y - GraphMetrics.node-height / 2) / 1px) < 24
+                ) {
+                    GraphCanvasAdapter.wire_completed(from_id, node.instance_id);
+                    return;
+                }
+            }
+        }
+    }
+}
diff --git a/gui/common/ui/components/pedals.slint b/gui/common/ui/components/pedals.slint
index 44f5df1..eafb804 100644
