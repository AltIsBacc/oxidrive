import { Palette } from "std-widgets.slint";

import { PedalsAdapter, ActivePedalInfo } from "@root/view_adapters.slint";

export component Pedal {
    in property <string> pedal_name;
    in property <int> type_id;

    // Fires once, on release. `x`/`y` are in this TouchArea's own local
    // coordinate space (Slint always reports mouse-x/y relative to the
    // TouchArea itself, not some shared ancestor), so they are NOT
    // directly usable as a canvas-space drop position on their own.
    // Whoever wires this up needs to translate using this tile's known
    // position relative to the canvas (e.g. via a shared ancestor
    // tracking absolute pointer position, since Slint has no built-in
    // cross-component drag-and-drop primitive).
    callback drag_started(int /* type_id */);
    callback drag_ended(int /* type_id */, length /* x */, length /* y */);

    width: 80px;
    height: 80px;

    Rectangle {
        background: Palette.alternate-background;
        border-radius: 8px;
        border-width: 1px;
        border-color: Palette.border;

        VerticalLayout {
            alignment: center;
            Text {
                text: root.pedal_name;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }
    }

    TouchArea {
        moved => {
            if (self.pressed) {
                root.drag_started(root.type_id);
            }
        }

        pointer-event(event) => {
            if (event.kind == PointerEventKind.up) {
                root.drag_ended(root.type_id, self.mouse-x, self.mouse-y);
            }
        }
    }
}

export component PedalArea {
    in-out property <[ActivePedalInfo]> chain: PedalsAdapter.active_chain;

    Rectangle {
        background: Palette.background;
        border-width: 1px;
        border-color: Palette.border;
        border-radius: 8px;

        if chain.length == 0 : Text {
            text: "Drag a pedal here";
            color: Palette.foreground.with-alpha(0.5);
        }

        HorizontalLayout {
            padding: 8px;
            spacing: 8px;
            for pedal[index] in chain : Rectangle {
                background: Palette.alternate-background;
                border-radius: 6px;
                width: 70px;

                VerticalLayout {
                    alignment: center;
                    Text { text: pedal.name; horizontal-alignment: center; }
                }

                TouchArea {
                    clicked => { PedalsAdapter.pedal_removed(pedal.instance_id); }
                }
            }
        }
    }
}
